# Noesis Lab — Environment Variables
# Copy to frontend/.env.local for development

# Optional: email service for access request notifications
# SENDGRID_API_KEY=your-sendgrid-key
# NOTIFICATION_EMAIL=your@email.com

# Optional: Resend (alternative to SendGrid)
# RESEND_API_KEY=your-resend-key

# No frontend API keys required for the base site
# Add here if you extend with additional services
